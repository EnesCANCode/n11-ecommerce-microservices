{
  "realm": "n11",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "USER", "description": "Regular customer" },
      { "name": "SELLER", "description": "Marketplace seller" },
      { "name": "ADMIN", "description": "Platform administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "n11-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "*"
      }
    },
    {
      "clientId": "n11-backend",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "secret": "n11-backend-secret"
    }
  ],
  "users": [
    {
      "username": "user@n11.com",
      "email": "user@n11.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["USER"]
    },
    {
      "username": "seller@n11.com",
      "email": "seller@n11.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "Seller",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["SELLER"]
    },
    {
      "username": "admin@n11.com",
      "email": "admin@n11.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["ADMIN"]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessCodeLifespan": 60
}
